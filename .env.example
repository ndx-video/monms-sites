# Backblaze B2 — copy to .env and fill in ( .env is gitignored )
#
# Used by: python scripts/publish_gallery_assets.py
#
# Object key:   [{B2_PATH_PREFIX}/]{category}/{slug}/{filename}
# Public URL:   {B2_PUBLIC_BASE_URL}/[{B2_PATH_PREFIX}/]{category}/{slug}/{filename}
#
# Example thumb URL after publish:
#   https://f000.backblazeb2.com/file/my-bucket/_base/_default/thumb.png

B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_PUBLIC_BASE_URL=https://f000.backblazeb2.com/file/YOUR-BUCKET-NAME
B2_PATH_PREFIX=
